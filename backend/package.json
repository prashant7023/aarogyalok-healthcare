{
    "name": "arogyalok-backend",
    "version": "1.0.0",
    "description": "ArogyaLok AI – Integrated Smart Healthcare Platform Backend",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "jest --runInBand --detectOpenHandles",
        "test:watch": "jest --watch --runInBand"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "forceExit": true,
        "clearMocks": true,
        "testTimeout": 30000
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.6.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "socket.io": "^4.7.5"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.5.0",
        "nodemon": "^3.1.4",
        "supertest": "^7.0.0"
    }
}
